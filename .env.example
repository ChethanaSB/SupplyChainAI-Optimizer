# ChainMind Configuration
# ────────────────────────────────────────

# ── API Keys ───────────────────────────────────────────────────────────
ALPHA_VANTAGE_KEY=your_alphavantage_key
NEWSAPI_KEY=your_newsapi_key
GEMINI_API_KEY=your_gemini_api_key

# ── Database & Cache ───────────────────────────────────────────────────
# For Neon (PostgreSQL): postgresql+asyncpg://user:pass@ep-xxx.neon.tech/dbname
DATABASE_URL=postgresql+asyncpg://chainmind:chainmind@localhost:5432/chainmind
# For Upstash (Redis): redis://default:pass@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Monitoring ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Feature Flags (Set to false to disable specific modules) ───────────
ENABLE_WEATHER=true
ENABLE_MARKET=true
ENABLE_NEWS=true
ENABLE_PORT_MOCK=true
